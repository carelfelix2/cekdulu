# Root / Web
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_SITE_NAME=CekDulu
NEXT_PUBLIC_DEFAULT_OG_IMAGE=/og/default.png

# API
NODE_ENV=development
PORT=4000
API_BASE_URL=http://localhost:4000
DATABASE_URL=postgresql://cekdulu:cekdulu@postgres:5432/cekdulu?schema=public
REDIS_URL=redis://redis:6379
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
OPENSEARCH_URL=http://opensearch:9200
JWT_ACCESS_SECRET=change-this-access-secret
JWT_REFRESH_SECRET=change-this-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
CORS_ORIGIN=http://localhost:3000

# Scraper
SCRAPER_ENV=development
SCRAPER_QUEUE_URL=amqp://guest:guest@rabbitmq:5672
SCRAPER_API_BASE_URL=http://api:4000
SCRAPER_PROXY_URL=
SCRAPER_CONCURRENCY=6
SCRAPER_RATE_LIMIT_PER_DOMAIN=2
SCRAPER_CRON=*/15 * * * *

# Search
ELASTICSEARCH_INDEX_PREFIX=cekdulu
